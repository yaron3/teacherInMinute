# ─── Firebase ────────────────────────────────────────────────────────────────
# Path to a service-account JSON downloaded from Firebase Console
# (Project settings → Service accounts → Generate new private key)
# Alternatively, paste the raw JSON string as the value.
FIREBASE_SERVICE_ACCOUNT=/path/to/service-account.json

# Your Realtime Database URL (found in Firebase Console → Realtime Database)
FIREBASE_DATABASE_URL=https://teacher-in-a-moment-default-rtdb.firebaseio.com

# ─── LLM ─────────────────────────────────────────────────────────────────────
# Base URL of the local LLM server.
#   Ollama default: http://localhost:11434
#   llama.cpp server: http://localhost:8080
#   Any OpenAI-compatible proxy: http://localhost:1234
LLM_BASE_URL=http://localhost:11434

# Model name to use.  Must be pulled in Ollama first: `ollama pull llama3.1`
LLM_MODEL=llama3.1

# "ollama" uses /api/generate (non-streaming).
# "openai" uses /v1/chat/completions (compatible with llama.cpp, LM Studio, vLLM, etc.)
LLM_API_TYPE=ollama

# Maximum seconds to wait for the LLM before giving up.
LLM_TIMEOUT_SECONDS=60

# ─── Behaviour ───────────────────────────────────────────────────────────────
# Milliseconds to wait after a question appears before generating an answer.
# During this window a human teacher can accept first; the AI will then skip.
ANSWER_DELAY_MS=1000

# Max simultaneous LLM calls (avoids overloading a local GPU).
MAX_CONCURRENT=2
