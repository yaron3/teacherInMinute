{
  "rules": {
    "teachers": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "teacherInvites": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": false
      }
    },
    "questions": {
      "$qid": {
        ".read": "auth != null",
        ".write": "auth != null && (data.child('teacherUid').val() == auth.uid || data.child('studentUid').val() == auth.uid || data.child('teacherId').val() == auth.uid || data.child('studentId').val() == auth.uid)"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    }
  }
}
